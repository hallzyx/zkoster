# Data source: "mock" (in-memory demo data, default) or "chain" (live Soroban).
ZKOSTER_DATA_SOURCE=mock

# Prover HTTP endpoint (the zkoster-prover `serve` command). Used by the batch
# creation flow to generate commitments + range proofs.
ZKOSTER_PROVER_URL=http://localhost:8787

# --- Required only when ZKOSTER_DATA_SOURCE=chain ---
# Deployed contract ids (see scripts/deploy_testnet.sh output).
ZKOSTER_PAYROLL_ID=
ZKOSTER_VERIFIER_ID=
ZKOSTER_COMPLIANCE_ID=

# Network (defaults to Stellar testnet if unset).
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015


ZKOSTER_ADMIN_SECRET_KEY=
ZKOSTER_EMPLOYEE_SECRET_KEY=
ZKOSTER_AUDITOR_SECRET_KEY=

